# Required — everything in this workshop runs on DeepSeek.
# Get a key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Optional — overrides the default model (deepseek/deepseek-v4-flash) used
# everywhere in mini_agent and the notebooks. Any litellm-supported model
# string works, e.g. deepseek/deepseek-chat or deepseek/deepseek-reasoner.
MODEL=

# Optional — enables the live web_search tool (act 2/3). Free key: https://app.tavily.com
# Without this, web_search returns a friendly "not configured" message instead of failing.
TAVILY_API_KEY=

# Optional — only needed if you want load_hf_gaia() to pull the REAL gated GAIA
# dataset instead of the bundled SAMPLE_GAIA questions in gaia.py. Not required to present.
HF_TOKEN=
