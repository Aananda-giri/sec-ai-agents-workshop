# Required — everything in this workshop runs on Gemini.
# Get a free key: https://aistudio.google.com/api-keys
GEMINI_API_KEY=

# Optional — enables the live web_search tool (act 2/3). Free key: https://app.tavily.com
# Without this, web_search returns a friendly "not configured" message instead of failing.
TAVILY_API_KEY=

# Optional — only needed if you want load_hf_gaia() to pull the REAL gated GAIA
# dataset instead of the bundled SAMPLE_GAIA questions in gaia.py. Not required to present.
HF_TOKEN=
